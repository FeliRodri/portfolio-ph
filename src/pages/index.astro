---
import { getImage } from "astro:assets";
import heroImage from "../assets/images/chercan.webp";
import Layout from "../layouts/Layout.astro";

const heroBg = await getImage({ src: heroImage, format: "webp" });
---

<Layout
	title="Inicio"
	description="Fotografía de Naturaleza a través de un Lente Tecnológico - Portfolio de Felipe Asenjo"
>
	<!-- Sección Hero (Portada) -->
	<div
		class="relative h-[60vh] w-full flex items-center justify-center overflow-hidden bg-scroll md:bg-fixed bg-bottom bg-cover bg-no-repeat"
		style={`background-image: url(${heroBg.src});`}
	>
		<div class="absolute inset-0 bg-black/50 z-0"></div>
		<div class="relative z-10 text-center text-white px-4">
			<h1 class="text-4xl md:text-5xl font-bold mb-2">Felipe Asenjo</h1>
			<p class="text-lg md:text-xl text-zinc-100">
				Fotografía de Naturaleza a través de un Lente Tecnológico
			</p>
		</div>
	</div>

	<div class="max-w-4xl mx-auto px-4 py-12 text-center">
		<section class="mb-16">
			<h2 class="text-3xl font-semibold mb-4">
				Bienvenido a mi espacio digital
			</h2>
			<p class="text-lg text-zinc-700 leading-relaxed max-w-2xl mx-auto">
				Aquí combino mis dos grandes pasiones: capturar la belleza de la
				vida salvaje y construir soluciones con código. Este portafolio
				no es solo una galería, es un proyecto vivo donde la tecnología
				potencia el arte de la fotografía.
			</p>
		</section>

		<section class="bg-white shadow-lg rounded-xl p-6 md:p-8">
			<h3 class="text-2xl font-semibold mb-4">Explora mi Bitácora</h3>
			<p class="text-zinc-600 mb-8 max-w-2xl mx-auto">
				En "El Laboratorio", documento mis procesos, experimentos y
				hallazgos. Descubre cómo utilizo scripts para procesar imágenes,
				analizo datos de mis fotografías y mucho más.
			</p>
			<a
				href="/laboratorio/"
				class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
			>
				Visitar El Laboratorio
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="h-5 w-5 ml-2"
					viewBox="0 0 20 20"
					fill="currentColor"
				>
					<path
						fill-rule="evenodd"
						d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
						clip-rule="evenodd"></path>
				</svg>
			</a>
		</section>
	</div>
</Layout>
