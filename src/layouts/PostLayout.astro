---
import type { CollectionEntry } from "astro:content";
import Layout from "./Layout.astro";

interface Props {
    post: CollectionEntry<"laboratorio">;
}

const { post } = Astro.props;
const { title, description, pubDate, author, image, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString("es-ES", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<Layout title={title} description={description}>
    <article class="max-w-3xl mx-auto px-4 py-8">
        {
            image && (
                <div class="mb-8 mx-auto max-w-2xl">
                    <div class="rounded-xl overflow-hidden aspect-[3/4] bg-zinc-100 dark:bg-zinc-700">
                        <img
                            src={image.url.src}
                            alt={image.alt}
                            class="w-full h-full object-contain"
                        />
                    </div>
                    <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-2 text-center">
                        {image.alt}
                    </p>
                </div>
            )
        }

        <header class="mb-8 text-center">
            <h1 class="text-4xl font-bold mb-4">
                {title}
            </h1>
            <div class="text-zinc-600 dark:text-zinc-400 mb-4">
                <time datetime={pubDate.toISOString()}>{formattedDate}</time>
                {author && <span> · Por {author}</span>}
            </div>
            {
                tags && tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 justify-center">
                        {tags.map((tag) => (
                            <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full text-sm">
                                #{tag}
                            </span>
                        ))}
                    </div>
                )
            }
        </header>

        <div class="prose prose-zinc max-w-none">
            <slot />
        </div>
    </article>
</Layout>

<style>
    .prose {
        @apply prose-headings:text-zinc-900 dark:prose-headings:text-zinc-100 prose-p:text-zinc-700 dark:prose-p:text-zinc-300 prose-a:text-blue-600 hover:prose-a:text-blue-800;
        @apply prose-strong:text-zinc-900 dark:prose-strong:text-zinc-100 prose-code:text-zinc-800 dark:prose-code:text-zinc-200 prose-pre:bg-zinc-900;
        @apply prose-img:rounded-xl prose-hr:border-zinc-300 dark:prose-hr:border-zinc-700;
    }
    :global(.dark .prose) {
        --tw-prose-body: #d4d4d8;
        --tw-prose-headings: #f4f4f5;
        --tw-prose-links: #60a5fa;
        --tw-prose-bold: #f4f4f5;
        --tw-prose-code: #cbd5e1;
        --tw-prose-pre-bg: #18181b;
    }
</style>
