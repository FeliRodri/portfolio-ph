---
const year = new Date().getFullYear();
---

<footer class="bg-white dark:bg-zinc-800 border-t mt-12">
    <div class="max-w-7xl mx-auto px-4 py-8">
        <div class="flex justify-between items-center">
            <div class="text-zinc-600 dark:text-zinc-400">
                © {year} Felipe Asenjo
            </div>
            <div class="flex space-x-6">
                <a
                    href="https://www.instagram.com/felipeasenjofotos/"
                    class="text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white"
                >
                    Instagram
                </a>
                <a
                    href="https://github.com/FeliRodri"
                    class="text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white"
                >
                    GitHub
                </a>
            </div>
        </div>
    </div>
</footer>
